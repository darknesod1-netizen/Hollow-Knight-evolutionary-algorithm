<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="HKPath.props" />
  
  <PropertyGroup>
    <TargetFramework>net472</TargetFramework>
    <AssemblyName>HKMod</AssemblyName>
    <RootNamespace>HKMod</RootNamespace>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="Assembly-CSharp">
      <HintPath>$(HKPath)\hollow_knight_Data\Managed\Assembly-CSharp.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(HKPath)\hollow_knight_Data\Managed\UnityEngine.CoreModule.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="MMHOOK_Assembly-CSharp">
      <HintPath>$(HKPath)\hollow_knight_Data\Managed\MMHOOK_Assembly-CSharp.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>

  <Target Name="PostBuild" AfterTargets="PostBuildEvent">
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll" 
          DestinationFolder="$(HKPath)\hollow_knight_Data\Managed\Mods\HKMod\" />
  </Target>
</Project>